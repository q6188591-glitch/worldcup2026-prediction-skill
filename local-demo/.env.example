PORT=5176
HOST=0.0.0.0

# Primary provider: currently used for every prediction.
OPENAI_BASE_URL=https://cpa.xiaoku88.com/v1
OPENAI_API_KEY=sk-your-primary-key
OPENAI_MODEL=gpt-5.5

# Fable provider: retained for later use, currently disabled in runtime because fable5 is banned.
FABLE_OPENAI_BASE_URL=https://zenmux.ai/api/v1
FABLE_OPENAI_API_KEY=sk-your-fable-key
FABLE_OPENAI_MODEL=anthropic/claude-fable-5
FABLE_FREE_USES=2

# Optional admin token. Without this, brief/model admin APIs are disabled.
ADMIN_TOKEN=

# Live prediction context. The server refreshes this RSS feed and injects it into every prediction prompt.
LIVE_NEWS_RSS_URL=https://www.espn.com/espn/rss/soccer/news
LIVE_REFRESH_MS=600000
REVIEW_SOURCE_URLS=https://www.espn.com/espn/rss/soccer/news,http://newsrss.bbc.co.uk/rss/sportonline_uk_edition/football/rss.xml
SCOREBOARD_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard

# Retained backup provider for later use; the runtime does not use it by default.
OTOKAPI_OPENAI_BASE_URL=https://otokapi.com/v1
OTOKAPI_OPENAI_API_KEY=sk-your-otokapi-key
OTOKAPI_OPENAI_MODEL=gpt-5.5
